{
    "name": "vue-admin-skeleton",
    "version": "0.9.0",
    "description": "A vue admin template with Element UI & axios & iconfont & permission control & lint",
    "author": "Rin <immane@163.com>",
    "scripts": {
        "test:unit": "vitest run",
        "test": "vitest run",
        "lint": "eslint --ext .js,.ts,.vue src",
        "type-check": "tsc --noEmit",
        "build": "vite build",
        "build:prod": "vite build --mode production",
        "build:stage": "vite build --mode staging",
        "dev": "vite",
        "preview": "vite preview",
        "svgo": "svgo -f src/icons/svg --config=src/icons/svgo.yml",
        "test:ci": "npm run type-check && npm run test"
    },
    "main": "background.js",
    "dependencies": {
        "@element-plus/icons-vue": "^2.3.2",
        "axios": "0.21.1",
        "core-js": "3.6.5",
        "element-plus": "^2.9.7",
        "export-excel-csv": "^1.0.1",
        "file-saver": "^2.0.5",
        "get-value": "^3.0.1",
        "i": "^0.3.6",
        "ipfs-http-client": "^54.0.1",
        "is-absolute-url": "^3.0.3",
        "js-cookie": "2.2.0",
        "jsoneditor": "^10.4.3",
        "normalize.css": "7.0.0",
        "nprogress": "0.2.0",
        "numbro": "^2.3.2",
        "path-to-regexp": "2.4.0",
        "prismjs": "^1.25.0",
        "qrcode": "^1.4.4",
        "vue": "^3.5.13",
        "vue-router": "^4.5.0",
        "vuex": "^4.1.0",
        "xlsx": "^0.16.9"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@types/node": "^25.9.1",
        "@typescript-eslint/parser": "^8.26.0",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitejs/plugin-vue-jsx": "^4.1.2",
        "@vue/compiler-sfc": "^3.5.13",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "9.5.1",
        "babel-plugin-dynamic-import-node": "2.3.3",
        "chalk": "2.4.2",
        "connect": "3.6.6",
        "eslint": "^8.57.1",
        "eslint-plugin-vue": "^9.32.0",
        "jsdom": "^26.0.0",
        "mockjs": "1.0.1-beta3",
        "runjs": "4.3.2",
        "sass": "1.26.8",
        "serve-static": "1.13.2",
        "svgo": "1.2.2",
        "typescript": "^6.0.3",
        "vite": "^5.4.0",
        "vitest": "^2.1.8",
        "vue-eslint-parser": "^9.4.3"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
    "engines": {
        "node": ">=8.9",
        "npm": ">= 3.0.0"
    },
    "license": "MIT"
}
