# just a flag
ENV = 'development'

# base api
VITE_BASE_API = ''

# dev proxy target, leave empty to disable proxy
VITE_PROXY_TARGET = 'http://127.0.0.1:8000'


# api prefixes proxied by vite.config.ts in development
VITE_API_PREFIX = '/api/v1'
VITE_AUTH_API_PREFIX = '/api/auth'
VITE_SYSTEM_API_PREFIX = '/system'

# base url
BASE_URL = 'admin'
